# Единый .gitignore для всего репозитория — раньше было разнесено по
# .gitignore/app/.gitignore/app/src-tauri/.gitignore, что усложняло
# понимание, что игнорируется и почему. Пути ниже указаны от корня
# репозитория (стандартное поведение git для .gitignore не в корне).

# --- Node / pnpm (app/) ---
app/node_modules/
app/dist/
app/dist-ssr/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Rust / Cargo (app/src-tauri/) ---
app/src-tauri/target/
# Generated by Tauri — схемы для автокомплита capabilities, не нужны
# в репозитории, регенерируются при сборке
app/src-tauri/gen/schemas/
# Бинарник vroxcore (наш форк hysteria2) — не коммитим, берётся из
# GitHub Release hysteria2-fork-v2.9.2-1 (см. core/installer.py в main)
app/src-tauri/binaries/

# --- macOS (macos-ext/) ---
# .xcodeproj регенерируется из project.yml через `xcodegen generate` —
# не коммитим сам сгенерированный проект (но см. doc-комментарий в
# macos-ext/build-testflight.sh: после регенерации manual-signing
# настройки в Release-конфигурации нужно проставить заново).
macos-ext/*.xcodeproj/
# GoNetunnel.xcframework — build-артефакт build-go-framework.sh
macos-ext/Frameworks/

# --- packaging/hysteria2-patch/ ---
# Клон apernet/hysteria + сборочные артефакты — пересобирается build.sh
# с нуля при каждом запуске, не часть исходников этого репозитория
packaging/hysteria2-patch/build/
packaging/hysteria2-patch/build-artifacts/
*.deb

# --- OS / редакторы ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln

# --- секреты (на случай, если когда-нибудь появятся локально) ---
.env
.env.local
*.pem
*.key
