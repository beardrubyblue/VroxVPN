{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vrox.vpn",
  "version": "4.0.0",
  "identifier": "com.vroxory.vpn",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vrox.vpn",
        "width": 420,
        "height": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/vroxcore"],
    "resources": [
      "resources/privileged_helper.sh",
      "resources/geoip/*",
      "resources/geosite/*"
    ],
    "linux": {
      "deb": {
        "depends": [
          "pkexec",
          "polkitd",
          "nftables",
          "iproute2",
          "procps",
          "iputils-ping"
        ],
        "postInstallScript": "scripts/postinst.sh",
        "postRemoveScript": "scripts/postrm.sh",
        "conflicts": ["vroxory-vpn"],
        "replaces": ["vroxory-vpn"],
        "provides": ["vroxory-vpn"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "entitlements": "macos/entitlements.plist",
      "signingIdentity": null
    }
  }
}
