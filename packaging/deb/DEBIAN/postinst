#!/bin/bash
set -e

# Python зависимости
pip3 install --break-system-packages requests PyYAML pillow 2>/dev/null || true

# polkit правило
cat > /etc/polkit-1/rules.d/49-vroxory-vpn.rules << 'POLKIT'
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.policykit.exec" && subject.isInGroup("sudo")) {
        var program = action.lookup("program");
        var allowed = ["hysteria2", "/sysctl", "/kill", "/ip", "/nft", "/apt-get", "/bin/sh"];
        for (var i = 0; i < allowed.length; i++) {
            if (program.indexOf(allowed[i]) !== -1) {
                return polkit.Result.YES;
            }
        }
    }
});
POLKIT

# Права
chmod +x /opt/vroxory-vpn/main.py
chmod 644 /usr/share/applications/vroxory-vpn.desktop

echo "Vroxory VPN установлен. Запуск: vroxory-vpn"
