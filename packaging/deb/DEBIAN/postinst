#!/bin/bash
set -e

# Python зависимости
pip3 install --break-system-packages requests PyYAML pillow 2>/dev/null || true

# polkit правило: passwordless pkexec ТОЛЬКО для точного пути нашего
# единого helper-скрипта и hysteria2-бинарника — без substring-matching
# по системным утилитам (sh/kill/ip/nft/sysctl/apt-get), который раньше
# давал любому процессу из группы sudo пройти pkexec без пароля вообще
# для чего угодно с этими подстроками в пути.
cat > /etc/polkit-1/rules.d/49-vroxory-vpn.rules << 'POLKIT'
polkit.addRule(function(action, subject) {
    if (action.id != "org.freedesktop.policykit.exec") {
        return;
    }
    if (!subject.isInGroup("sudo")) {
        return;
    }
    var program = action.lookup("program");
    var allowed = [
        "/opt/vroxory-vpn/core/privileged_helper.sh",
        "/usr/local/bin/hysteria2",
        "/home/" + subject.user + "/.local/bin/hysteria2"
    ];
    if (allowed.indexOf(program) !== -1) {
        return polkit.Result.YES;
    }
});
POLKIT

# Права
chmod +x /opt/vroxory-vpn/main.py
chmod +x /opt/vroxory-vpn/core/privileged_helper.sh
chmod 644 /usr/share/applications/com.vroxory.vpn.desktop

# старое имя .desktop-файла (до переименования под application_id) —
# убираем, чтобы в меню не осталась дублирующая запись "Vroxory VPN"
rm -f /usr/share/applications/vroxory-vpn.desktop

# обновляем кэш иконок и базу .desktop-файлов, чтобы новая иконка и
# имя "vrox.vpn" подхватились сразу, без перезахода в сессию
gtk-update-icon-cache -f /usr/share/icons/hicolor 2>/dev/null || true
update-desktop-database /usr/share/applications 2>/dev/null || true

echo "vrox.vpn установлен. Запуск: vroxory-vpn"
